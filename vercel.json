{
    "version": 2,
    "buildCommand": "cd App/secure_password_demo/client && npm install && npm run build",
    "outputDirectory": "App/secure_password_demo/client/dist",
    "framework": "vite",
    "rewrites": [
        {
            "source": "/api/(.*)",
            "destination": "/api/index.ts"
        },
        {
            "source": "/(.*)",
            "destination": "/App/secure_password_demo/client/index.html"
        }
    ]
}